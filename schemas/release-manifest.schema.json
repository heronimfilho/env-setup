{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heronimfilho/env-setup/schemas/release-manifest.schema.json",
  "title": "env-setup release manifest",
  "type": "object",
  "required": [
    "version",
    "commit",
    "archiveSha256",
    "minimumWindowsBuild"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "archiveSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "minimumWindowsBuild": {
      "type": "integer",
      "minimum": 19041
    },
    "releaseNotes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
